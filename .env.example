# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salonpay_dev?schema=public"

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_PREFIX=salonpay

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL (para links en emails de verificacion y reset)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@salonpay.com

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Optional: AWS S3 (for production)
# AWS_REGION=us-east-1
# AWS_BUCKET=salonpay-uploads
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# Google Calendar Integration (Sprint 2)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/google-calendar/callback

# WhatsApp Business Cloud API (Sprint 2)
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token-min-32-chars
